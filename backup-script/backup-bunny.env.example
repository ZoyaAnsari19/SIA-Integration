# Copy to backup-bunny.env and fill values. Same as MLM-API Bunny config.
# Do not commit backup-bunny.env (it is in .gitignore).

export BUNNY_STORAGE_ZONE_NAME=mlm-cdn
export BUNNY_STORAGE_ENDPOINT=https://storage.bunnycdn.com
export BUNNY_STORAGE_API_KEY=your-storage-zone-password-from-bunny-dashboard
