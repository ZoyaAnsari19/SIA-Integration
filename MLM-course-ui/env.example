# Unified MLM-API Base URL
# Development: http://localhost:3000/api/v1
# Production: https://api.secureinfiniteassociation.com/api/v1
NEXT_PUBLIC_API_BASE_URL=https://api.secureinfiniteassociation.com/api/v1

# Razorpay Configuration (for course payments)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# Application Settings
NEXT_PUBLIC_APP_NAME=Secure Infinite Association
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Instructions:
# 1. Copy this file to .env.local: cp env.example .env.local
# 2. Update values as needed
# 3. Restart Next.js dev server



