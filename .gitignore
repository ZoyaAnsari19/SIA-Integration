# =============================================================================
# SIA / MLM monorepo — root .gitignore
# =============================================================================

# --- Dependencies ---
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
jspm_packages/

# --- Build / cache outputs ---
dist/
build/
out/
**/.next/
**/.turbo/
**/.nuxt/
.cache/
.parcel-cache/
*.tsbuildinfo
next-env.d.ts
.serverless/
.fusebox/
.dynamodb/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# --- Environment & secrets (never commit) ---
.env
.env.*
!.env.example
!**/.env.example
!**/env.example
**/.env.backup*
**/.env.bak
**/.env.backup
backup-script/backup-bunny.env

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
backup-script/backup.log
backup-script/.backup-work

# --- Test / coverage ---
coverage/
.nyc_output/
*.lcov

# --- OS & IDE ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Runtime / temp ---
pids/
*.pid
*.seed
*.pid.lock
*.tgz
.yarn-integrity
.node_repl_history
.tern-port
*.pem
*.local

# --- Databases (local dev) ---
*.sqlite
*.sqlite3
*.db
prisma/dev.db
postgres-data/
**/postgres-data/

# --- Database backups & dumps (GitHub 100MB file limit) ---
mlm-db.sql
**/db-backup/
production-db-backup/
backup-script/production-db-backup/
**/*prod-backup*.sql
**/*prod-dump*.sql
azure-kube-stage/prod-dump-for-stage-*.sql
*.dump

# --- Docker / uploads ---
uploads/
**/uploads/

# --- Python (mlm-chat-engine) ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
.envrc

# --- Deploy / hosting ---
.vercel/

# --- Misc project-specific ---
MLM-Admin-ui/../secure-pay-user/
payment-gateway/secretKey
**/secretKey
