PgBoss job setup & workers

Commission services & logic

Wallet and ledger transactional functions

Comprehensive Jest test coverage

Swagger API documentation

🧭 Example Business Rule (Eligibility Release)
if (eligibility[level] && pendingCommissions.length) {
  for (const pending of pendingCommissions) {
    const isSourceActive = await isUserActive(pending.source_user_id);
    const isReceiverActive = await isUserActive(pending.receiver_user_id);

    if (isSourceActive && isReceiverActive) {
      await addLedgerAndWallet({
        receiverId: pending.receiver_user_id,
        sourceId: pending.source_user_id,
        amount: pending.amount,
        type: pending.commission_type,
        meta: pending.metadata,
      });
    }

    await db.query(`DELETE FROM pending_commissions WHERE id = $1`, [pending.id]);
  }
}

