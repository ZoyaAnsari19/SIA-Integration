// Prisma schema for MLM backend (PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id               BigInt   @id @default(autoincrement())
  uuid             String   @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String?
  email            String?  @unique
  referrer_user_id BigInt?  @db.BigInt
  created_at       DateTime @default(now()) @db.Timestamptz

  @@map("users")
}

model packages {
  id                      Int      @id @default(autoincrement())
  name                    String
  price                   Decimal  @db.Decimal(18, 2)
  self_monthly            Decimal? @db.Decimal(18, 2)
  global_ids              Int?
  global_monthly_per_id   Decimal? @db.Decimal(18, 2)
  recurring_rate_percent  Decimal? @db.Decimal(6, 4)
  validity_months         Int      @default(12)
  created_at              DateTime @default(now()) @db.Timestamptz
  updated_at              DateTime @default(now()) @db.Timestamptz

  @@map("packages")
}

model purchases {
  id           BigInt   @id @default(autoincrement())
  user_id      BigInt   @db.BigInt
  package_id   Int
  amount       Decimal  @db.Decimal(18, 2)
  purchased_at DateTime @default(now()) @db.Timestamptz
  active_until DateTime @db.Timestamptz
  status       String   @default("completed")

  @@index([user_id])
  @@index([package_id])
  @@map("purchases")
}

enum CommissionType {
  SELF
  GLOBAL_HELPING
  SPOT
  MONTHLY
}

model user_tree_paths {
  ancestor_id   BigInt @db.BigInt
  descendant_id BigInt @db.BigInt
  depth         Int

  @@id([ancestor_id, descendant_id])
  @@map("user_tree_paths")
}

model ledger_entries {
  id               BigInt         @id @default(autoincrement())
  receiver_user_id BigInt         @db.BigInt
  source_user_id   BigInt         @db.BigInt
  purchase_id      BigInt?        @db.BigInt
  commission_type  CommissionType
  amount           Decimal        @db.Decimal(18, 2)
  credited_at      DateTime       @default(now()) @db.Timestamptz
  settled          Boolean        @default(false)
  metadata         Json?
  idempotency_key  String?        @unique

  @@index([receiver_user_id])
  @@index([source_user_id])
  @@index([purchase_id])
  @@map("ledger_entries")
}

model wallet_transactions {
  id               BigInt   @id @default(autoincrement())
  receiver_user_id BigInt   @db.BigInt
  ledger_entry_id  BigInt?
  amount           Decimal  @db.Decimal(18, 2)
  created_at       DateTime @default(now()) @db.Timestamptz
  idempotency_key  String?

  @@index([receiver_user_id])
  @@index([ledger_entry_id])
  @@map("wallet_transactions")
}

model pending_commissions {
  id               BigInt         @id @default(autoincrement())
  receiver_user_id BigInt         @db.BigInt
  source_user_id   BigInt         @db.BigInt
  purchase_id      BigInt?        @db.BigInt
  level            Int
  commission_type  CommissionType?
  amount           Decimal        @db.Decimal(18, 2)
  created_at       DateTime       @default(now()) @db.Timestamptz
  metadata         Json?

  @@index([receiver_user_id])
  @@index([source_user_id])
  @@index([level])
  @@map("pending_commissions")
}

model scheduled_commissions {
  id               BigInt         @id @default(autoincrement())
  receiver_user_id BigInt         @db.BigInt
  source_user_id   BigInt?        @db.BigInt
  purchase_id      BigInt?        @db.BigInt
  commission_type  CommissionType
  monthly_amount   Decimal        @db.Decimal(18, 2)
  daily_amount     Decimal        @db.Decimal(18, 2)
  total_credited   Decimal        @default(0) @db.Decimal(18, 2)
  days_processed   Int            @default(0)
  start_date       DateTime       @db.Date
  end_date         DateTime       @db.Date
  idempotency_key  String?        @unique

  @@index([receiver_user_id])
  @@index([source_user_id])
  @@index([purchase_id])
  @@map("scheduled_commissions")
}

model level_eligibility {
  user_id    BigInt   @id @db.BigInt
  eligibility Json    @db.JsonB
  updated_at  DateTime @default(now()) @db.Timestamptz

  @@map("level_eligibility")
}

model commission_rules {
  id          Int      @id @default(autoincrement())
  type        String
  level       Int?
  percent     Decimal? @db.Decimal(6, 4)
  fixed_amount Decimal? @db.Decimal(18, 2)
  eligibility Json?
  created_at  DateTime @default(now()) @db.Timestamptz

  @@map("commission_rules")
}

model user_balances {
  user_id    BigInt  @id @db.BigInt
  balance    Decimal @default(0) @db.Decimal(18, 2)
  updated_at DateTime @default(now()) @db.Timestamptz

  @@map("user_balances")
}


