# SMTP (Email OTP — P2P transfer)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASS=your-gmail-app-password
# SMTP_FROM=no-reply@secureinfiniteassociation.com

# Fast2SMS (SMS / OTP)
# FAST2SMS_API_KEY=your-fast2sms-api-key
# FAST2SMS_SENDER_ID=SIAPVT
# Login credentials SMS - DLT template ID (default in code: 206002)
# FAST2SMS_LOGIN_TEMPLATE_ID=206002
# Generic OTP - Registration / Forgot Password / Forgot PIN (DLT = 0.25 Rs; if empty = Quick SMS 5 Rs)
# FAST2SMS_GENERIC_OTP_TEMPLATE_ID=
# Name Change OTP - DLT template ID from Fast2SMS dashboard (DLT = 0.25 Rs; if empty = Quick SMS 5 Rs)
# FAST2SMS_NAME_CHANGE_OTP_TEMPLATE_ID=
# P2P Transfer OTP - DLT template ID from Fast2SMS dashboard
# FAST2SMS_P2P_OTP_TEMPLATE_ID=
# Transaction PIN (transaction password) OTP - DLT template ID from Fast2SMS dashboard
# FAST2SMS_TRANSACTION_PIN_OTP_TEMPLATE_ID=

# Bunny Stream (Video delivery for courses)
# BUNNY_STREAM_LIBRARY_ID=your-bunny-library-id
# BUNNY_STREAM_API_KEY=your-bunny-api-key
# BUNNY_STREAM_TOKEN_KEY=your-super-secret-bunny-stream-token-key

# Razorpay Payment Gateway (for course purchases)
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
