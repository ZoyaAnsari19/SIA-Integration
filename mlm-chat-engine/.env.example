PORT=8088

# Same database as MLM-API
DATABASE_URL=postgresql://user:password@localhost:5432/mlm

# Same JWT secret as MLM-API
JWT_SECRET=replace-me
ADMIN_JWT_SECRET=replace-me

# Redis for session memory
REDIS_URL=redis://localhost:6379/0

# Gemini
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-pro

# MLM-API base URL (for write actions; JWT forwarded)
MLM_API_BASE_URL=http://localhost:3000

